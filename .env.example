# Canonical site URL (used in sitemap, SEO). Must match the domain you use in Google Search Console.
# Examples: https://www.swetkaar.com or https://swetkaar.ai
NEXT_PUBLIC_SITE_URL=https://www.swetkaar.com

# Contact form: submissions are sent to this email (via Web3Forms)
NEXT_PUBLIC_ADMIN_EMAIL=hello@swetkaar.com

# Web3Forms access key (get one at https://web3forms.com)
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_access_key_here
